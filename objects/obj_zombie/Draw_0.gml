 // 1. Обязательно рисуем самого зомби (иначе он станет невидимым!)
draw_self();

// 2. Рисуем полоску здоровья, только если зомби ранен
if (hp < hp_max) {
    
    // Вычисляем процент оставшегося здоровья
    var hp_percent = (hp / hp_max) * 100;
    
    // Задаем координаты для шкалы над головой зомби
    // x - 20 и x + 20 — это ширина полоски (40 пикселей)
    // y - 40 — высота над центром зомби (подстройте под размер вашего спрайта)
    var x1 = x - 20;
    var y1 = y - 40; 
    var x2 = x + 20;
    var y2 = y - 34; // Толщина полоски будет 6 пикселей
    
    // Встроенная функция GameMaker для рисования шкалы здоровья
    // Параметры: координаты углов, процент, цвет фона, цвет мин. здоровья, цвет макс. здоровья, направление, показывать ли рамку, показывать ли фон.
    draw_healthbar(x1, y1, x2, y2, hp_percent, c_black, c_red, c_green, 0, true, true);
}