// 1. Проверяем, существует ли физически объект в игре
// (например, если его случайно удалили из ресурсов или кода инициализации)
if (!object_exists(obj_game_master)) {
    show_message("Критическая ошибка: Главный объект игры не найден в ресурсах!");
    game_end();
    exit;
}

// 2. Альтернатива: Проверка критического файла на диске (например, спрайта или конфига)
// Если игрок удалит этот файл из папки с игрой, она не запустится
if (!file_exists(working_directory + "critical_asset.txt")) {
    show_message("Ошибка запуска: Отсутствует обязательный компонент игры!");
    game_end();
    exit;
}

// 3. Создаем этот обязательный объект динамически, если его нет на сцене
if (!instance_exists(obj_game_master)) {
    instance_create_depth(0, 0, 0, obj_game_master);
}

// Если все проверки пройдены успешны — переходим в главное меню
room_goto(rm_main_menu);